# Production Dockerfile - requires pre-built dist folder
# Build locally first: pnpm build
# Then: podman build --platform linux/amd64 -f Dockerfile.prod -t docker.io/tmshuu/warehouse-web:latest .

FROM --platform=linux/amd64 nginx:alpine

# Copy custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy pre-built assets
COPY dist /usr/share/nginx/html

# Expose port 80
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
